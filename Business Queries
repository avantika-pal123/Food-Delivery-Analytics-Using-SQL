-- 1. Display customer name, city, and total number of orders placed.
SELECT c.customer_name,c.city , COUNT(o.order_id) as total_orders
FROM customers c 
 LEFT JOIN
 orders o ON
 c.customer_id= o.order_id
 GROUP BY c.customer_id, c.customer_name, c.city;



-- 2. Find customers who have never placed an order.
SELECT
    c.customer_id,
    c.customer_name,
    c.city
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_id IS NULL;

-- 3. List the top 10 customers by total spending.
SELECT
    c.customer_id,
    c.customer_name,
    SUM(o.order_amount) AS total_spending
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
ORDER BY total_spending DESC
LIMIT 10;

-- 4. Find customers who ordered from more than one restaurant.
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(DISTINCT o.restaurant_id) AS restaurants_ordered
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING COUNT(DISTINCT o.restaurant_id) > 1;

-- 5.Show each customer's first and latest order date.
SELECT
    c.customer_id,
    c.customer_name,
    MIN(o.order_date) AS first_order,
    MAX(o.order_date) AS latest_order
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name;

-- 6.Find customers whose average order value is above the overall average.
SELECT
    c.customer_id,
    c.customer_name,
    AVG(o.order_amount) AS avg_order
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING AVG(o.order_amount) >
(
    SELECT AVG(order_amount)
    FROM orders
);

-- 7.Display customers who haven't ordered in the last 30 days.
SELECT
    c.customer_id,
    c.customer_name,
    MAX(o.order_date) AS last_order
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING MAX(o.order_date) <
DATE_SUB(
    (SELECT MAX(order_date) FROM orders),
    INTERVAL 30 DAY
)
OR MAX(o.order_date) IS NULL;

-- 8. Find customers who placed the highest number of completed orders.
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(o.order_id) AS completed_orders
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_status = 'Completed'
GROUP BY
    c.customer_id,
    c.customer_name
ORDER BY completed_orders DESC;


-- 9.Show customer-wise total amount spent on each restaurant.
SELECT
    c.customer_name,
    r.restaurant_name,
    SUM(o.order_amount) AS total_spent
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
JOIN restaurants r
ON o.restaurant_id = r.restaurant_id
GROUP BY
    c.customer_name,
    r.restaurant_name
ORDER BY total_spent DESC;


-- 10. Find customers who only ordered from one restaurant
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(DISTINCT o.restaurant_id) AS restaurant_count
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING COUNT(DISTINCT o.restaurant_id) = 1;



-- 11. Display each restaurant along with the total number of orders received.

SELECT
    r.restaurant_id,
    r.restaurant_name,
    COUNT(o.order_id) AS total_orders
FROM restaurants r
LEFT JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.restaurant_id,
    r.restaurant_name
ORDER BY total_orders DESC;



-- 12. Find the restaurant with the highest revenue.
SELECT
    r.restaurant_id,
    r.restaurant_name,
    SUM(o.order_amount) AS total_revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.restaurant_id,
    r.restaurant_name
ORDER BY total_revenue DESC
LIMIT 1;



-- 13. Find the restaurant with the lowest revenue.
SELECT
    r.restaurant_id,
    r.restaurant_name,
    SUM(o.order_amount) AS total_revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.restaurant_id,
    r.restaurant_name
ORDER BY total_revenue ASC
LIMIT 1;



-- 14. Display restaurant name along with average order value.
SELECT
    r.restaurant_name,
    ROUND(AVG(o.order_amount),2) AS average_order_value
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.restaurant_name
ORDER BY average_order_value DESC;


-- 15. Find restaurants that have never received an order.

SELECT
    r.restaurant_id,
    r.restaurant_name
FROM restaurants r
LEFT JOIN orders o
ON r.restaurant_id = o.restaurant_id
WHERE o.order_id IS NULL;



-- 16. Display Top 5 restaurants based on completed orders.
SELECT
    r.restaurant_name,
    COUNT(o.order_id) AS completed_orders
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
WHERE o.order_status = 'Completed'
GROUP BY
    r.restaurant_name
ORDER BY completed_orders DESC
LIMIT 5;



-- 17. Find restaurants with average rating above 4.5 and more than 20 orders.

SELECT
    r.restaurant_name,
    ROUND(AVG(r.rating),2) AS average_rating,
    COUNT(o.order_id) AS total_orders
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.restaurant_name
HAVING
AVG(r.rating) > 4.5
AND COUNT(o.order_id) > 20;


-- 18. Display total revenue generated by each cuisine.
SELECT
    r.cuisine,
    SUM(o.order_amount) AS total_revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
GROUP BY
    r.cuisine
ORDER BY total_revenue DESC;


-- 19. Find restaurants that received cancelled orders.


Restaurants with order cancellations.

SELECT DISTINCT
    r.restaurant_name
FROM restaurants r
JOIN orders o
ON r.restaurant_id = o.restaurant_id
WHERE o.order_status = 'Cancelled';


-- 20. Display restaurant-wise cancellation percentage.

SELECT
    r.restaurant_name,
    COUNT(o.order_id) AS total_orders,
    SUM(CASE
            WHEN o.order_status='Cancelled'
            THEN 1
            ELSE 0
        END) AS cancelled_orders,
    ROUND(
        SUM(CASE
                WHEN o.order_status='Cancelled'
                THEN 1
                ELSE 0
            END)*100.0/
        COUNT(o.order_id),2
    ) AS cancellation_percentage
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
GROUP BY
    r.restaurant_name
ORDER BY cancellation_percentage DESC;

-- 21. Display customer name, restaurant name, and order amount.
SELECT
    c.customer_name,
    r.restaurant_name,
    o.order_amount
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
JOIN restaurants r
ON o.restaurant_id = r.restaurant_id
ORDER BY o.order_amount DESC;



-- 22. Find the highest-value order placed by each customer.
SELECT
    c.customer_id,
    c.customer_name,
    MAX(o.order_amount) AS highest_order
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
ORDER BY highest_order DESC;


-- 23. Display monthly revenue.
SELECT
    YEAR(order_date) AS year,
    MONTHNAME(order_date) AS month,
    SUM(order_amount) AS monthly_revenue
FROM orders
GROUP BY
    YEAR(order_date),
    MONTH(order_date),
    MONTHNAME(order_date)
ORDER BY
    YEAR(order_date),
    MONTH(order_date);



-- 24. Find daily order count.
SELECT
    order_date,
    COUNT(order_id) AS total_orders
FROM orders
GROUP BY order_date
ORDER BY order_date;



-- 25. Display average order value for every city.
SELECT
    c.city,
    ROUND(AVG(o.order_amount),2) AS average_order_value
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY c.city
ORDER BY average_order_value DESC;


-- 26. Find customers whose latest order is above ₹1000.
SELECT
    c.customer_id,
    c.customer_name,
    MAX(o.order_date) AS latest_order,
    MAX(o.order_amount) AS latest_order_amount
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING MAX(o.order_amount) > 1000;


-- 27. Display total revenue generated every month.
SELECT
    MONTHNAME(order_date) AS month,
    SUM(order_amount) AS revenue
FROM orders
GROUP BY
    MONTH(order_date),
    MONTHNAME(order_date)
ORDER BY MONTH(order_date);



-- 28. Find the busiest day based on total orders.
SELECT
    order_date,
    COUNT(order_id) AS total_orders
FROM orders
GROUP BY order_date
ORDER BY total_orders DESC
LIMIT 1;

-- 29. Find the busiest month based on revenue.
SELECT
    MONTHNAME(order_date) AS month,
    SUM(order_amount) AS total_revenue
FROM orders
GROUP BY
    MONTH(order_date),
    MONTHNAME(order_date)
ORDER BY total_revenue DESC
LIMIT 1;



-- 30. Display orders along with payment method and payment status.
SELECT
    o.order_id,
    c.customer_name,
    r.restaurant_name,
    o.order_amount,
    p.payment_method,
    p.payment_status
FROM orders o
JOIN customers c
ON o.customer_id = c.customer_id
JOIN restaurants r
ON o.restaurant_id = r.restaurant_id
JOIN payments p
ON o.order_id = p.order_id
ORDER BY o.order_id;


-- 31. Find total revenue collected through each payment method.
SELECT
    payment_method,
    SUM(amount) AS total_revenue
FROM payments
WHERE payment_status='Success'
GROUP BY payment_method
ORDER BY total_revenue DESC;



-- 32. Display payment success rate.
SELECT
ROUND(
COUNT(CASE WHEN payment_status='Success' THEN 1 END)*100.0/
COUNT(*),2
) AS payment_success_rate
FROM payments;



-- 33. Find customers whose payment failed.
SELECT
    c.customer_id,
    c.customer_name,
    p.payment_status
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN payments p
ON o.order_id=p.order_id
WHERE p.payment_status='Failed';



-- 34. Display restaurant revenue considering only successful payments.
SELECT
    r.restaurant_name,
    SUM(p.amount) AS revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
JOIN payments p
ON o.order_id=p.order_id
WHERE p.payment_status='Success'
GROUP BY r.restaurant_name
ORDER BY revenue DESC;


-- 35. Find average payment amount by payment method.
SELECT
    payment_method,
    ROUND(AVG(amount),2) AS average_payment
FROM payments
GROUP BY payment_method;


-- 36. Display Top 5 customers who made the highest online payments.
SELECT
    c.customer_name,
    SUM(p.amount) AS total_paid
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN payments p
ON o.order_id=p.order_id
WHERE p.payment_method IN ('UPI','Credit Card','Debit Card','Net Banking')
AND p.payment_status='Success'
GROUP BY c.customer_name
ORDER BY total_paid DESC
LIMIT 5;


-- 37. Find total failed payment amount.
SELECT
SUM(amount) AS failed_payment_amount
FROM payments
WHERE payment_status='Failed';


-- 38. Display payment method used most frequently.
SELECT
payment_method,
COUNT(*) AS total_transactions
FROM payments
GROUP BY payment_method
ORDER BY total_transactions DESC
LIMIT 1;


-- 39. Find customers who always pay using UPI.
SELECT
    c.customer_id,
    c.customer_name
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN payments p
ON o.order_id=p.order_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING
COUNT(DISTINCT p.payment_method)=1
AND MAX(p.payment_method)='UPI';


-- 40. Compare successful vs failed transactions by month.
SELECT
MONTHNAME(payment_date) AS month,
SUM(CASE
WHEN payment_status='Success' THEN 1
ELSE 0
END) AS successful_payments,
SUM(CASE
WHEN payment_status='Failed' THEN 1
ELSE 0
END) AS failed_payments
FROM payments
GROUP BY
MONTH(payment_date),
MONTHNAME(payment_date)
ORDER BY MONTH(payment_date);


-- 41. Find repeat customers for every restaurant.
SELECT
r.restaurant_name,
c.customer_name,
COUNT(o.order_id) AS total_orders
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
JOIN customers c
ON o.customer_id=c.customer_id
GROUP BY
r.restaurant_name,
c.customer_name
HAVING COUNT(o.order_id)>1
ORDER BY total_orders DESC;


-- 42. Find customers who ordered from restaurants in different cities.
SELECT
c.customer_name,
COUNT(DISTINCT r.city) AS cities_ordered
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN restaurants r
ON o.restaurant_id=r.restaurant_id
GROUP BY c.customer_name
HAVING COUNT(DISTINCT r.city)>1;


-- 43. Display Customer Lifetime Value (CLV).
SELECT
c.customer_id,
c.customer_name,
COUNT(o.order_id) AS total_orders,
SUM(o.order_amount) AS lifetime_value
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
GROUP BY
c.customer_id,
c.customer_name
ORDER BY lifetime_value DESC;


-- 44. Find customers contributing to the Top 80% of revenue.
WITH customer_sales AS
(
SELECT
customer_id,
SUM(order_amount) AS revenue
FROM orders
GROUP BY customer_id
),
ranked AS
(
SELECT *,
SUM(revenue) OVER(ORDER BY revenue DESC) AS running_revenue,
SUM(revenue) OVER() AS total_revenue
FROM customer_sales
)
SELECT *
FROM ranked
WHERE running_revenue<=0.80*total_revenue;


-- 45. Find restaurants whose revenue is above the average restaurant revenue.
SELECT
r.restaurant_name,
SUM(o.order_amount) AS revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
GROUP BY r.restaurant_name
HAVING SUM(o.order_amount)>
(
SELECT AVG(total_revenue)
FROM
(
SELECT
restaurant_id,
SUM(order_amount) AS total_revenue
FROM orders
GROUP BY restaurant_id

);

-- 46. Display customer retention rate month-wise.
SELECT
MONTHNAME(order_date) AS month,
COUNT(DISTINCT customer_id) AS retained_customers
FROM orders
GROUP BY
MONTH(order_date),
MONTHNAME(order_date)
ORDER BY MONTH(order_date);



-- 47. Find the average time gap between two consecutive orders for each customer.
SELECT
customer_id,
ROUND(AVG(days_gap),2) AS average_gap_days
FROM
(
SELECT
customer_id,
DATEDIFF(
order_date,
LAG(order_date)
OVER(PARTITION BY customer_id ORDER BY order_date)
) AS days_gap
FROM orders
)t
WHERE days_gap IS NOT NULL
GROUP BY customer_id;



-- 48. Rank restaurants based on revenue within each city.
SELECT
city,
restaurant_name,
revenue,
RANK() OVER
(
PARTITION BY city
ORDER BY revenue DESC
) AS city_rank
FROM
(
SELECT
r.city,
r.restaurant_name,
SUM(o.order_amount) AS revenue
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
GROUP BY
r.city,
r.restaurant_name
);

-- 49. Find the top-selling cuisine in every city.
SELECT *
FROM
(
SELECT
r.city,
r.cuisine,
SUM(o.order_amount) AS revenue,
RANK() OVER
(
PARTITION BY r.city
ORDER BY SUM(o.order_amount) DESC
) AS ranking
FROM restaurants r
JOIN orders o
ON r.restaurant_id=o.restaurant_id
GROUP BY
r.city,
r.cuisine
)
WHERE ranking=1;

-- 50. Business Dashboard Report
SELECT
c.customer_name,
r.restaurant_name,
COUNT(o.order_id) AS total_orders,
SUM(o.order_amount) AS total_spending,
ROUND(AVG(o.order_amount),2) AS average_order_value,
MAX(o.order_date) AS last_order_date,
p.payment_method
FROM customers c
JOIN orders o
ON c.customer_id=o.customer_id
JOIN restaurants r
ON o.restaurant_id=r.restaurant_id
JOIN payments p
ON o.order_id=p.order_id
GROUP BY
c.customer_name,
r.restaurant_name,
p.payment_method
ORDER BY total_spending DESC;




