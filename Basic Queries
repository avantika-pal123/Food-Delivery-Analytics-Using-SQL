-- --------------------------------------------------------------------------------------CUSTOMER ANALYSIS-----------------------------------------------------

-- 1. Display customer name, city, and total number of orders placed.
SELECT c.customer_name,c.city , COUNT(o.order_id) as total_orders
FROM customers c 
 LEFT JOIN
 orders o ON
 c.customer_id= o.order_id
 GROUP BY c.customer_id, c.customer_name, c.city;



-- 2. Find customers who have never placed an order.
SELECT
    c.customer_id,
    c.customer_name,
    c.city
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_id IS NULL;

-- 3. List the top 10 customers by total spending.
SELECT
    c.customer_id,
    c.customer_name,
    SUM(o.order_amount) AS total_spending
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
ORDER BY total_spending DESC
LIMIT 10;

-- 4. Find customers who ordered from more than one restaurant.
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(DISTINCT o.restaurant_id) AS restaurants_ordered
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING COUNT(DISTINCT o.restaurant_id) > 1;

-- 5.Show each customer's first and latest order date.
SELECT
    c.customer_id,
    c.customer_name,
    MIN(o.order_date) AS first_order,
    MAX(o.order_date) AS latest_order
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name;

-- 6.Find customers whose average order value is above the overall average.
SELECT
    c.customer_id,
    c.customer_name,
    AVG(o.order_amount) AS avg_order
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING AVG(o.order_amount) >
(
    SELECT AVG(order_amount)
    FROM orders
);

-- 7.Display customers who haven't ordered in the last 30 days.
SELECT
    c.customer_id,
    c.customer_name,
    MAX(o.order_date) AS last_order
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING MAX(o.order_date) <
DATE_SUB(
    (SELECT MAX(order_date) FROM orders),
    INTERVAL 30 DAY
)
OR MAX(o.order_date) IS NULL;

-- 8. Find customers who placed the highest number of completed orders.
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(o.order_id) AS completed_orders
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_status = 'Completed'
GROUP BY
    c.customer_id,
    c.customer_name
ORDER BY completed_orders DESC;


-- 9.Show customer-wise total amount spent on each restaurant.
SELECT
    c.customer_name,
    r.restaurant_name,
    SUM(o.order_amount) AS total_spent
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
JOIN restaurants r
ON o.restaurant_id = r.restaurant_id
GROUP BY
    c.customer_name,
    r.restaurant_name
ORDER BY total_spent DESC;


-- 10. Find customers who only ordered from one restaurant
SELECT
    c.customer_id,
    c.customer_name,
    COUNT(DISTINCT o.restaurant_id) AS restaurant_count
FROM customers c
JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY
    c.customer_id,
    c.customer_name
HAVING COUNT(DISTINCT o.restaurant_id) = 1;





